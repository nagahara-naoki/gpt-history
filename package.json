{
  "name": "gpt-history",
  "version": "0.1.0",
  "private": true,
  "description": "ChatGPT の入力欄で ↑↓ キーで過去の送信履歴を呼び出せる Chrome 拡張機能",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "pnpm": {
    "overrides": {
      "rollup@<2.80.0": "^2.80.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.6.3",
    "vite": "^6.4.2"
  }
}
