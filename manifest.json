{
  "manifest_version": 3,
  "name": "gpt-history",
  "version": "0.1.0",
  "description": "ChatGPT の入力欄で ↑↓ キーで過去の送信履歴を呼び出せる拡張機能",
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
